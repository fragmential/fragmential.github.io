#!/bin/bash
set -euo pipefail

for cmd in pandoc pdf2svg python3 sed sort find grep; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Missing required command: $cmd" >&2
    exit 1
  fi
done

if [ ! -d attachments ]; then
  echo "Missing required directory: attachments" >&2
  exit 1
fi

# Keep no-argument web labels in sync with the LaTeX environment defaults.
tex_default_label() {
  sed -n "s|.*\\\\newenvironment{$1}\\[1\\]\\[\\([^]]*\\)\\].*|\\1|p" main.tex | head -n 1 | sed 's/[&\]/\\&/g; s/|/\\|/g'
}

NOTES_LABEL=$(tex_default_label notes)
EXPERIMENTS_LABEL=$(tex_default_label experiments)

# Parse trim comments from main.tex and crop PDFs accordingly.
# Each \includegraphics line can have a comment: % trim:L,B,R,T (in bp)
# LaTeX trim order: L,B,R,T from the page edges.
# We convert PDF->SVG first, then adjust the SVG viewBox to apply the crop.

# Convert all PDFs to SVG
find attachments -name '*.pdf' -not -path 'attachments/cropped/*' | while read -r f; do
  rel="${f#attachments/}"
  mkdir -p "attachments/cropped/$(dirname "$rel")"
  pdf2svg "$f" "attachments/cropped/${rel%.pdf}.svg"
done

# Apply trim to SVGs by adjusting the viewBox
# 1bp = 1/72 inch; pdf2svg uses 72dpi so 1bp = 1 SVG user unit
sed -n 's/.*{\(attachments\/[^}]*\.pdf\)}.*% trim:\([0-9]*\),\([0-9]*\),\([0-9]*\),\([0-9]*\).*/\1 \2 \3 \4 \5/p' main.tex | \
  sort -u | while read -r file L B R T; do
    rel="${file#attachments/}"
    svg="attachments/cropped/${rel%.pdf}.svg"
    [ -f "$svg" ] || continue
    # Extract current viewBox or width/height
    python3 -c "
import re, sys
with open('$svg', 'r') as f:
    content = f.read()
L, B, R, T = $L, $B, $R, $T
# Try viewBox first
m = re.search(r'viewBox=\"([^\"]+)\"', content)
if m:
    vx, vy, vw, vh = [float(x) for x in m.group(1).split()]
else:
    # Fall back to width/height attributes
    wm = re.search(r'width=\"([0-9.]+)', content)
    hm = re.search(r'height=\"([0-9.]+)', content)
    vx, vy, vw, vh = 0, 0, float(wm.group(1)), float(hm.group(1))
# Apply trim: L from left, T from top, R from right, B from bottom
nvx = vx + L
nvy = vy + T
nvw = vw - L - R
nvh = vh - T - B
new_vb = f'{nvx} {nvy} {nvw} {nvh}'
# Update or insert viewBox
if m:
    content = content[:m.start(1)] + new_vb + content[m.end(1):]
else:
    content = content.replace('<svg ', f'<svg viewBox=\"{new_vb}\" ', 1)
with open('$svg', 'w') as f:
    f.write(content)
"
  done

# Build web version: swap .pdf -> cropped .svg paths, strip trim/clip,
# expose web-only and supporting-notes blocks as marker headings for post-processing.
sed -e 's|attachments/\([^}]*\)\.pdf|attachments/cropped/\1.svg|g' \
    -e 's/, *trim=[^,]*, *clip//g' \
    -e 's/\\shortstack{\([^\\]*\)\\\\\([^}]*\)}/\1\\newline \2/g' \
    -e 's|\\begin{weboptional}{\(.*\)}|\\paragraph{__WEBOPTSTART__:\1}|' \
    -e 's|\\end{weboptional}|\\paragraph{__WEBOPTEND__}|' \
    -e 's|\\begin{notes}\[\(.*\)\]|\\paragraph{__NOTESSTART__@@@LABEL@@@\1@@@LABEL@@@}\\begin{itemize}|' \
    -e "s|\\\\begin{notes}|\\\\paragraph{__NOTESSTART__@@@LABEL@@@${NOTES_LABEL}@@@LABEL@@@}\\\\begin{itemize}|" \
    -e 's|\\end{notes}|\\end{itemize}\\paragraph{__NOTESEND__}|' \
    -e 's|\\begin{experiments}\[\(.*\)\]|\\paragraph{__EXPSTART__@@@LABEL@@@\1@@@LABEL@@@}|' \
    -e "s|\\\\begin{experiments}|\\\\paragraph{__EXPSTART__@@@LABEL@@@${EXPERIMENTS_LABEL}@@@LABEL@@@}|" \
    -e 's|\\end{experiments}|\\paragraph{__EXPEND__}|' \
    main.tex > main_web.tex

pandoc main_web.tex -s -o index.html --katex --citeproc \
  --bibliography citations.bib --template template.html \
  --toc --toc-depth 1

# Post-process index.html:
#  - Wrap __WEBOPTSTART__:title ... __WEBOPTEND__ blocks in <details class="weboptional">
#  - Wrap __NOTESSTART__ ... __NOTESEND__ blocks in <details class="notes">
#  - Wrap __EXPSTART__ ... __EXPEND__ blocks in <details class="experiments">
python3 <<'PYEOF'
import re, html as htmllib

with open('index.html') as f:
    html = f.read()

responsive_math_script = r'''<script>document.addEventListener("DOMContentLoaded", function () {
 var mathElements = Array.prototype.slice.call(document.getElementsByClassName("math"));
 var inlineMath = [];
 var displayMath = [];
 var macros = [];
 var resizeTimer = null;

 function renderMath(element, tex, displayMode) {
  katex.render(tex, element, {
   displayMode: displayMode,
   throwOnError: false,
   macros: macros,
   fleqn: false
  });
 }

 function normalizeDisplayTex(tex) {
  return tex.replace(/\s+/g, ' ').trim();
 }

 function extractEquationBody(tex) {
  var match = tex.trim().match(/^\\begin\{equation\}([\s\S]*?)\\end\{equation\}$/);
  return match ? normalizeDisplayTex(match[1]) : null;
 }

 function replaceTopLevel(tex, rules) {
  var out = '';
  var depth = 0;

  for (var i = 0; i < tex.length; i++) {
   var matchedRule = null;

   if (depth === 0) {
    for (var r = 0; r < rules.length; r++) {
     var rule = rules[r];
     if (tex.slice(i, i + rule.token.length) === rule.token) {
      matchedRule = rule;
      break;
     }
    }
   }

   if (matchedRule) {
    out += matchedRule.replacement;
    i += matchedRule.token.length - 1;
    continue;
   }

   var ch = tex.charAt(i);
   if (ch === '{') depth += 1;
   if (ch === '}') depth = Math.max(0, depth - 1);
   out += ch;
  }

  return out;
 }

 function buildAlignedEquation(body) {
  return '\\begin{equation}\\begin{aligned} & ' +
   body.trim().replace(/^(?:&\s*)+/, '') +
   ' \\end{aligned}\\end{equation}';
 }

 function buildGatheredEquation(body) {
  return '\\begin{equation}\\begin{gathered} ' +
   body.trim().replace(/^(?:\\\\\s*)+/, '') +
   ' \\end{gathered}\\end{equation}';
 }

 function buildDisplayVariant(tex, mode) {
  var body = extractEquationBody(tex);
  if (!body) return tex;

  var rules;
  var builder;

  if (mode === 'wrapped') {
   rules = [
    { token: ', \\qquad', replacement: ', \\\\ & ' },
    { token: ',\\qquad', replacement: ', \\\\ & ' },
    { token: '\\qquad', replacement: '\\\\ & ' },
    { token: ' + ', replacement: ' \\\\ & + ' },
    { token: ' = ', replacement: ' \\\\ & = ' },
    { token: ' \\approx ', replacement: ' \\\\ & \\approx ' },
    { token: ' \\otimes ', replacement: ' \\\\ & \\otimes ' }
   ];
   builder = buildAlignedEquation;
  } else {
   rules = [
    { token: ', \\qquad', replacement: ', \\\\ ' },
    { token: ',\\qquad', replacement: ', \\\\ ' },
    { token: '\\qquad', replacement: '\\\\ ' }
   ];
   builder = buildGatheredEquation;
  }

  var rewrittenBody = replaceTopLevel(body, rules);
  if (rewrittenBody === body) return tex;
  return builder(rewrittenBody);
 }

 function getDisplayMetrics(element) {
  var katexHtml = element.querySelector('.katex-html');
  var tag = katexHtml ? katexHtml.querySelector('.tag') : null;
  var bases = katexHtml ? Array.prototype.filter.call(katexHtml.children, function (child) {
   return child.classList && child.classList.contains('base');
  }) : [];
  var contentWidth = 0;

  if (bases.length) {
   contentWidth = Math.max.apply(null, bases.map(function (base) {
    return base.getBoundingClientRect().width;
   }));
  } else if (katexHtml) {
   contentWidth = katexHtml.getBoundingClientRect().width;
  }

  var available = element.getBoundingClientRect().width - (tag ? tag.getBoundingClientRect().width + 12 : 0);
  return {
   available: Math.max(0, available),
   contentWidth: contentWidth,
   overflow: Math.max(0, contentWidth - available)
  };
 }

 function setDisplayScale(element, scale) {
  element.style.setProperty('--display-equation-scale', scale.toFixed(3));
 }

 function applyBestScale(element) {
  setDisplayScale(element, 1);
  var metrics = getDisplayMetrics(element);
  if (!metrics.contentWidth || metrics.overflow <= 1) return metrics;

  var scale = Math.max(0.75, Math.min(1, metrics.available / metrics.contentWidth));
  setDisplayScale(element, scale);
  return getDisplayMetrics(element);
 }

 function updateOverflowClass(element) {
  element.classList.toggle('has-overflow', getDisplayMetrics(element).overflow > 1);
 }

 function renderResponsiveDisplay(element) {
  var originalTex = element.dataset.originalTex;
  var preferredTex = element.dataset.preferredTex;
  var wrappedTex = element.dataset.wrappedTex;

  setDisplayScale(element, 1);
  renderMath(element, originalTex, true);
  if (getDisplayMetrics(element).overflow <= 1) {
   updateOverflowClass(element);
   return;
  }

  if (preferredTex !== originalTex) {
   renderMath(element, preferredTex, true);
   if (getDisplayMetrics(element).overflow <= 1) {
    updateOverflowClass(element);
    return;
   }
  }

  var scaledMetrics = applyBestScale(element);
  if (scaledMetrics.overflow <= 1) {
   updateOverflowClass(element);
   return;
  }

  if (wrappedTex !== preferredTex) {
   setDisplayScale(element, 1);
   renderMath(element, wrappedTex, true);
   if (getDisplayMetrics(element).overflow <= 1) {
    updateOverflowClass(element);
    return;
   }
   applyBestScale(element);
  }

  updateOverflowClass(element);
 }

 mathElements.forEach(function (element) {
  if (element.tagName !== 'SPAN') return;

  var tex = element.textContent || '';
  if (element.classList.contains('display')) {
   element.dataset.originalTex = tex;
   element.dataset.preferredTex = buildDisplayVariant(tex, 'preferred');
   element.dataset.wrappedTex = buildDisplayVariant(tex, 'wrapped');
   displayMath.push(element);
  } else {
   inlineMath.push({ element: element, tex: tex });
  }
 });

 inlineMath.forEach(function (entry) {
  renderMath(entry.element, entry.tex, false);
 });

 function renderDisplayMath() {
  displayMath.forEach(renderResponsiveDisplay);
 }

 renderDisplayMath();

 window.addEventListener('resize', function () {
  clearTimeout(resizeTimer);
  resizeTimer = setTimeout(renderDisplayMath, 80);
 });
});</script>'''

html = re.sub(
    r'<script>document\.addEventListener\("DOMContentLoaded", function \(\) \{\s*var mathElements = document\.getElementsByClassName\("math"\);.*?</script>',
    lambda _: responsive_math_script,
    html,
    count=1,
    flags=re.DOTALL)

def ordinal_day(day):
    if 10 <= day % 100 <= 20:
        suffix = 'th'
    else:
        suffix = {1: 'st', 2: 'nd', 3: 'rd'}.get(day % 10, 'th')
    return f'{day}{suffix}'

def format_display_date(date_text):
    date_text = date_text.strip()
    iso = re.fullmatch(r'(\d{4})-(\d{1,2})-(\d{1,2})', date_text)
    month_names = [
        'January', 'February', 'March', 'April', 'May', 'June',
        'July', 'August', 'September', 'October', 'November', 'December'
    ]

    if iso:
        year, month, day = (int(part) for part in iso.groups())
        if not 1 <= month <= 12:
            return date_text
        return f'{ordinal_day(day)} {month_names[month - 1]} {year}'

    day_month_year = re.fullmatch(
        r'(\d{1,2})\s+(' + '|'.join(month_names) + r')\s+(\d{4})',
        date_text)
    if day_month_year:
        day, month_name, year = day_month_year.groups()
        return f'{ordinal_day(int(day))} {month_name} {year}'

    return date_text

html = re.sub(
    r'(<span class="article-date">)([^<]+)(</span>)',
    lambda m: m.group(1) + format_display_date(m.group(2)) + m.group(3),
    html)

def wrap_weboptional(m):
    title = htmllib.unescape(m.group(1)).strip()
    body = m.group(2)
    return (f'<details class="weboptional"><summary>{title}</summary>\n'
            f'{body}\n</details>')

html = re.sub(
    r'<h[1-6][^>]*>\s*__WEBOPTSTART__:([^<]+?)\s*</h[1-6]>(.*?)<h[1-6][^>]*>\s*__WEBOPTEND__\s*</h[1-6]>',
    wrap_weboptional, html, flags=re.DOTALL)

def _details(class_name, label, body):
    label = label.strip()
    return (f'<details class="{class_name}"><summary>{label}</summary>\n'
            f'{body}\n</details>')

def _notes_with_label(m):
    label = m.group(1).strip()
    body = m.group(2)
    return _details('notes', label, body)

html = re.sub(
    r'<h[1-6][^>]*>\s*__NOTESSTART__@@@LABEL@@@(.*?)@@@LABEL@@@\s*</h[1-6]>(.*?)<h[1-6][^>]*>\s*__NOTESEND__\s*</h[1-6]>',
    _notes_with_label, html, flags=re.DOTALL)

def _exp(m):
    label = m.group(1).strip()
    body = m.group(2)
    return _details('experiments', label, body)

html = re.sub(
    r'<h[1-6][^>]*>\s*__EXPSTART__@@@LABEL@@@(.*?)@@@LABEL@@@\s*</h[1-6]>(.*?)<h[1-6][^>]*>\s*__EXPEND__\s*</h[1-6]>',
    _exp, html, flags=re.DOTALL)

with open('index.html', 'w') as f:
    f.write(html)
PYEOF

missing_assets=0
while IFS= read -r asset; do
  if [ ! -f "$asset" ]; then
    echo "Missing generated asset referenced by index.html: $asset" >&2
    missing_assets=1
  fi
done < <(grep -o 'attachments/cropped/[^" >)]*\.svg' index.html | sort -u)

if [ "$missing_assets" -ne 0 ]; then
  exit 1
fi

rm -f main_web.tex
